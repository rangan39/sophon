{
  "name": "sophon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "benchmark:download": "node scripts/benchmark_model_download.mjs",
    "budget:bundle": "node scripts/check_bundle_budget.mjs",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "test:metrics": "node --experimental-strip-types --test tests/generation-metrics.test.mjs",
    "smoke:ui": "node scripts/smoke_ui.mjs",
    "smoke:prompt": "node scripts/smoke_prompt.mjs",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit --incremental false",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "clsx": "^2.1.1",
    "hash-wasm": "^4.12.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.468.0",
    "next": "^16.2.10",
    "p-queue": "^9.3.2",
    "p-retry": "^7.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "postcss": "$postcss",
    "sharp": "0.35.3"
  }
